<launch>
    <node pkg="tf2_ros" type="static_transform_publisher" name="base_to_camera_link"
          args="-0.1 0 1.35 0 0.08715 0 0.99619 base_link camera_link" />

    <node pkg="tf2_ros" type="static_transform_publisher" name="camera_link_to_optical_frame"
          args="0 0 0 -0.5 0.5 -0.5 0.5 camera_link camera_optical_frame" />

</launch>